@prefix dcterms:     <http://purl.org/dc/terms/> .
@prefix owl:         <http://www.w3.org/2002/07/owl#> .
@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann:        <http://purl.org/vocab/vann/> .

@prefix oslc_ldm:    <http://open-services.net/ns/ldm#> .

# The ontology

oslc_ldm:
  a owl:Ontology ;
  dcterms:title "OSLC Link Discovery Management (LDM) Vocabulary" ;
  rdfs:label "OSLC Link Discovery Management (LDM) Vocabulary" ;
  dcterms:description "All vocabulary URIs defined in the OSLC Link Discovery Management (LDM) namespace."^^rdf:XMLLiteral ;
  vann:preferredNamespacePrefix "oslc_ldm" ;
  dcterms:publisher <https://open-services.net/about/> ;
  dcterms:issued "2026-05-20"^^<http://www.w3.org/2001/XMLSchema#date> ;
  dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dcterms:source <https://docs.oasis-open-projects.org/oslc-op/ldm/v1.0/link-discovery-management-vocab.ttl> ;
  dcterms:isPartOf <https://docs.oasis-open-projects.org/oslc-op/ldm/v1.0/link-discovery-management-spec.html> ;
  dcterms:hasVersion "PSD" ;
  dcterms:dateCopyrighted  "2023" .

# Classes

oslc_ldm:LinkDiscoveryRequest
        a                 rdfs:Class ;
        rdfs:comment      "A request to discover links to or from a set of resources, optionally filtered by link predicates and direction." ;
        rdfs:isDefinedBy  oslc_ldm: ;
        rdfs:label        "LinkDiscoveryRequest" .

# Properties

oslc_ldm:resources
        a                 rdf:Property ;
        rdfs:comment      "The target resources for which links are being discovered." ;
        rdfs:isDefinedBy  oslc_ldm: ;
        rdfs:label        "resources" .

oslc_ldm:linkPredicates
        a                 rdf:Property ;
        rdfs:comment      "The link type predicates used to filter the discovered links. If not specified, all link predicates are returned." ;
        rdfs:isDefinedBy  oslc_ldm: ;
        rdfs:label        "linkPredicates" .

oslc_ldm:direction
        a                 rdf:Property ;
        rdfs:comment      "The direction of links to discover. A value of 'incoming' discovers only incoming links. A value of 'any' discovers both incoming and outgoing links. Defaults to 'incoming'." ;
        rdfs:isDefinedBy  oslc_ldm: ;
        rdfs:label        "direction" .
