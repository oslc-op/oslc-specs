@prefix dcterms:    <http://purl.org/dc/terms/> .
@prefix oslc:       <http://open-services.net/ns/core#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .

@prefix oslc_ldm:   <http://open-services.net/ns/ldm#> .
@prefix : <http://open-services.net/ns/ldm/shapes/1.0#> .

# OSLC Link Discovery Management Resource Shapes

:
  a oslc:ResourceShapeConstraints ;
  dcterms:title "OSLC Link Discovery Management (LDM) Constraints" ;
  rdfs:label "OSLC Link Discovery Management (LDM) Constraints" ;
  dcterms:description "All constraints defined for the OSLC Link Discovery Management (LDM) namespace."^^rdf:XMLLiteral ;
  dcterms:publisher <https://open-services.net/about/> ;
  dcterms:issued "2026-05-20"^^<http://www.w3.org/2001/XMLSchema#date> ;
  dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dcterms:source <https://docs.oasis-open-projects.org/oslc-op/ldm/v1.0/link-discovery-management-shapes.ttl> ;
  dcterms:isPartOf <https://docs.oasis-open-projects.org/oslc-op/ldm/v1.0/link-discovery-management-spec.html> ;
  dcterms:hasVersion "PSD" ;
  dcterms:dateCopyrighted  "2023" .

:LinkDiscoveryRequestShape
    a                       oslc:ResourceShape ;
    oslc:describes          oslc_ldm:LinkDiscoveryRequest ;
    dcterms:title           "LinkDiscoveryRequest" ;
    dcterms:description     """A request to discover links to or from a set of resources, optionally
filtered by link predicates and direction."""^^rdf:XMLLiteral ;
    oslc:property
        :resources,
        :linkPredicates,
        :direction
    .

:resources  a                 oslc:Property ;
        oslc:name                "resources" ;
        oslc:propertyDefinition  oslc_ldm:resources ;
        oslc:occurs              oslc:One-or-many ;
        oslc:valueType           oslc:Resource ;
        oslc:representation      oslc:Reference ;
        oslc:range               oslc:Any ;
        dcterms:description      "The target resource URIs for which links are being discovered."^^rdf:XMLLiteral .

:linkPredicates  a            oslc:Property ;
        oslc:name                "linkPredicates" ;
        oslc:propertyDefinition  oslc_ldm:linkPredicates ;
        oslc:occurs              oslc:Zero-or-many ;
        oslc:valueType           oslc:Resource ;
        oslc:representation      oslc:Reference ;
        oslc:range               oslc:Any ;
        dcterms:description      "The link type predicates used to filter the discovered links. If not specified, all link predicates are returned."^^rdf:XMLLiteral .

:direction  a                 oslc:Property ;
        oslc:name                "direction" ;
        oslc:propertyDefinition  oslc_ldm:direction ;
        oslc:occurs              oslc:Zero-or-one ;
        oslc:valueType           xsd:string ;
        dcterms:description      "The direction of links to discover. A value of 'incoming' discovers only incoming links. A value of 'any' discovers both incoming and outgoing links. Defaults to 'incoming'."^^rdf:XMLLiteral .
